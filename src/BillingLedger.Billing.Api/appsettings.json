      },
      "CircuitBreaker": {
        "SamplingDuration": "00:00:30",
        "FailureRatio": 0.5,
        "MinimumThroughput": 5,
        "BreakDuration": "00:00:15"
      },
      "AttemptTimeout": {
        "Timeout": "00:00:10"
      }
    }
